# v14 High-Conviction Meta-Strategy Bot
# Copy to .env and fill in your values. Never commit .env to git!

# ── Hyperliquid Credentials ──
HL_PRIVATE_KEY=
HL_WALLET_ADDRESS=

# ── Trading ──
SYMBOL=BTC
LEVERAGE=10
POSITION_EQUITY_PCT=1.0

# ── Strategy Overrides ──
CONVICTION_THRESHOLD=0.35
MAX_HOLD_HOURS=24
TRAIL_ACTIVATE_PCT=0.6
TRAIL_DISTANCE_PCT=0.3
SL_MULTIPLIER=2.0

# ── Bot Mode ──
LIVE_TRADING=false
TESTNET=true
DRY_RUN=true

# ── myQuant Polling ──
POLL_INTERVAL_SEC=5
POLL_WINDOW_SEC=600
